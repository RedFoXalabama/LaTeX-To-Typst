// Il documento è composto da uno o più item
file = { SOI ~ item+ ~ EOI }

// Un item può essere un comando o del semplice testo
item = _{ command | text }

// Testo: qualsiasi carattere che non sia l'inizio di un comando
text = { (!"\\" ~ ANY)+ }

// Comando: \nome{argomento}
// Usiamo regole semplici: nome solo lettere, argomento tutto ciò che non è "}"
command = { "\\" ~ name ~ "{" ~ argument ~ "}" }
name    = { ASCII_ALPHA+ }
argument = { (!"}" ~ ANY)* }